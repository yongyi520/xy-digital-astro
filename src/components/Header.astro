---
import { site } from "../content/site";
import Icon from "./Icon.astro";
---

<nav class="sticky top-0 z-50 border-b border-white/10 bg-[color:rgba(7,12,20,0.72)] backdrop-blur-xl">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-3">
      <span class="flex h-10 w-10 items-center justify-center rounded-2xl border border-[var(--color-primary)]/30 bg-[var(--color-primary)]/10 text-[var(--color-primary)]">
        <Icon name="spark" class="h-5 w-5" />
      </span>
      <span class="font-display text-lg font-bold uppercase tracking-[0.2em] text-white">{site.name}</span>
    </a>
    <div class="hidden items-center gap-7 md:flex">
      {
        site.nav.map((item) => (
          <a class="text-sm font-semibold text-slate-300 transition hover:text-white" href={item.href}>
            {item.label}
          </a>
        ))
      }
      <a
        href={site.calendlyUrl}
        target="_blank"
        rel="noreferrer"
        class="rounded-full border border-[var(--color-primary)]/40 bg-[var(--color-primary)] px-5 py-2 text-sm font-bold text-slate-950 shadow-[0_18px_40px_rgba(95,198,255,0.22)] transition hover:-translate-y-0.5 hover:bg-[var(--color-primary-strong)]"
      >
        Book a Consult
      </a>
    </div>
  </div>
</nav>
