---
import { site } from "../content/site";
import Icon from "./Icon.astro";
---

<footer id="contact" class="border-t border-white/10 bg-[rgba(5,9,16,0.92)]">
  <div class="mx-auto grid max-w-7xl gap-10 px-4 py-14 sm:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:px-8">
    <div class="space-y-5">
      <div class="flex items-center gap-3">
        <span class="flex h-10 w-10 items-center justify-center rounded-2xl border border-[var(--color-primary)]/30 bg-[var(--color-primary)]/10 text-[var(--color-primary)]">
          <Icon name="spark" class="h-5 w-5" />
        </span>
        <div>
          <p class="font-display text-lg font-bold uppercase tracking-[0.16em] text-white">{site.name}</p>
          <p class="text-sm text-slate-400">{site.tagline}</p>
        </div>
      </div>
      <p class="max-w-xl text-sm leading-7 text-slate-400">
        If you want to discuss agency automations, AI systems, or operational architecture, contact us directly or book a consult.
      </p>
    </div>
    <div class="grid gap-6 rounded-[28px] border border-white/10 bg-white/4 p-6 shadow-[0_24px_70px_rgba(0,0,0,0.28)]">
      <div class="flex items-start gap-3">
        <span class="mt-0.5 text-[var(--color-primary)]"><Icon name="mail" class="h-5 w-5" /></span>
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.24em] text-slate-500">Email</p>
          <a class="mt-1 block text-sm font-semibold text-white hover:text-[var(--color-primary)]" href={`mailto:${site.email}`}>
            {site.email}
          </a>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <span class="mt-0.5 text-[var(--color-primary)]"><Icon name="pin" class="h-5 w-5" /></span>
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.24em] text-slate-500">Address</p>
          <p class="mt-1 text-sm font-medium text-slate-300">{site.address}</p>
        </div>
      </div>
      <div class="flex flex-wrap gap-5 border-t border-white/10 pt-5 text-sm text-slate-400">
        {
          site.footerLinks.map((item) => (
            <a
              class="transition hover:text-white"
              href={item.href}
              target={item.href.startsWith("https://calendly.com") ? "_blank" : undefined}
              rel={item.href.startsWith("https://calendly.com") ? "noreferrer" : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </div>
      <p class="text-xs uppercase tracking-[0.2em] text-slate-600">© 2026 {site.name}. All rights reserved.</p>
    </div>
  </div>
</footer>
