---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";
import { site } from "../content/site";
---

<BaseLayout
  title={site.seo.title}
  description={site.seo.description}
>
  <Header />

  <main>
    <section class="hero-grid relative overflow-hidden">
      <div class="absolute inset-x-0 top-0 h-full pointer-events-none">
        <div class="hero-glow hero-glow-left"></div>
        <div class="hero-glow hero-glow-right"></div>
        <div class="grid-fade"></div>
      </div>
      <div class="relative mx-auto grid max-w-7xl gap-16 px-4 py-20 sm:px-6 lg:grid-cols-[1.05fr_0.95fr] lg:px-8 lg:py-28">
        <div class="flex flex-col gap-8">
          <div class="inline-flex w-fit items-center gap-3 rounded-full border border-[var(--color-primary)]/25 bg-[var(--color-primary)]/10 px-4 py-2 text-[11px] font-extrabold uppercase tracking-[0.28em] text-[var(--color-primary)]">
            <span class="relative flex h-2.5 w-2.5">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[var(--color-primary)] opacity-70"></span>
              <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-[var(--color-primary)]"></span>
            </span>
            {site.hero.eyebrow}
          </div>

          <div class="space-y-6">
            <h1 class="font-display text-5xl font-extrabold leading-[0.98] tracking-[-0.04em] text-white sm:text-6xl lg:text-7xl">
              {site.hero.titleLead}
              <span class="text-[var(--color-primary)]"> {site.hero.titleAccent}</span>
            </h1>
            <p class="max-w-2xl text-lg leading-8 text-slate-300 sm:text-xl">
              {site.hero.body}
            </p>
          </div>

          <div class="flex flex-col gap-4 sm:flex-row">
            <a
              href={site.calendlyUrl}
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center justify-center gap-2 rounded-full bg-[var(--color-primary)] px-7 py-4 text-base font-extrabold text-slate-950 shadow-[0_22px_50px_rgba(95,198,255,0.28)] transition hover:-translate-y-0.5 hover:bg-[var(--color-primary-strong)]"
            >
              Book a 1-Hour Consult
              <Icon name="arrow" class="h-4 w-4" />
            </a>
            <a
              href="#services"
              class="inline-flex items-center justify-center rounded-full border border-white/14 bg-white/6 px-7 py-4 text-base font-bold text-white transition hover:border-white/30 hover:bg-white/10"
            >
              See Services
            </a>
          </div>

          <div class="flex flex-wrap items-center gap-6 border-t border-white/10 pt-6">
            <p class="text-sm text-slate-400">
              {site.hero.trust}
            </p>
          </div>
        </div>

        <div class="relative lg:pt-6">
          <div class="glass-panel tilt-panel overflow-hidden rounded-[32px] p-4">
            <div class="hero-monitor relative min-h-[520px] rounded-[28px] border border-white/10 p-6">
              <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(95,198,255,0.18),transparent_35%),radial-gradient(circle_at_bottom_right,rgba(39,99,255,0.2),transparent_30%)]"></div>
              <div class="relative flex h-full flex-col justify-between">
                <div class="grid gap-4 sm:grid-cols-[1.1fr_0.9fr]">
                  <div class="rounded-[24px] border border-white/10 bg-slate-950/60 p-5">
                    <p class="text-xs font-bold uppercase tracking-[0.24em] text-slate-500">Automation signal</p>
                    <div class="mt-6 space-y-4">
                      <div>
                        <p class="text-sm text-slate-400">Qualified actions today</p>
                        <p class="mt-1 text-4xl font-black text-white">4.2k+</p>
                      </div>
                      <div class="space-y-2">
                        <div class="h-2 rounded-full bg-white/8">
                          <div class="h-2 w-[72%] rounded-full bg-[var(--color-primary)]"></div>
                        </div>
                        <p class="text-xs uppercase tracking-[0.22em] text-slate-500">System throughput increasing</p>
                      </div>
                    </div>
                  </div>
                  <div class="rounded-[24px] border border-white/10 bg-white/5 p-5">
                    <p class="text-xs font-bold uppercase tracking-[0.24em] text-slate-500">Agent status</p>
                    <div class="mt-6 grid gap-3">
                      <div class="rounded-2xl border border-emerald-400/20 bg-emerald-400/10 px-4 py-3 text-sm text-emerald-200">
                        Lead routing agent active
                      </div>
                      <div class="rounded-2xl border border-cyan-400/20 bg-cyan-400/10 px-4 py-3 text-sm text-cyan-100">
                        Support retrieval synced
                      </div>
                      <div class="rounded-2xl border border-white/10 bg-slate-950/60 px-4 py-3 text-sm text-slate-300">
                        Audit logs available
                      </div>
                    </div>
                  </div>
                </div>

                <div class="grid gap-4 lg:grid-cols-[1.1fr_0.9fr]">
                  <div class="rounded-[24px] border border-white/10 bg-white/5 p-5">
                    <p class="text-xs font-bold uppercase tracking-[0.24em] text-slate-500">Logic map</p>
                    <div class="mt-6 grid gap-3">
                      <div class="flow-node">
                        <span>Inbound trigger</span>
                        <span>01</span>
                      </div>
                      <div class="flow-node flow-node-accent">
                        <span>Qualification rules</span>
                        <span>02</span>
                      </div>
                      <div class="flow-node">
                        <span>CRM + notification sync</span>
                        <span>03</span>
                      </div>
                    </div>
                  </div>
                  <div class="rounded-[24px] border border-white/10 bg-slate-950/60 p-5">
                    <p class="text-xs font-bold uppercase tracking-[0.24em] text-slate-500">Core stack</p>
                    <div class="mt-6 grid grid-cols-2 gap-3">
                      <div class="stack-pill">n8n</div>
                      <div class="stack-pill">Make</div>
                      <div class="stack-pill">APIs</div>
                      <div class="stack-pill">Vector DB</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="floating-stat">
            <p class="text-xs font-bold uppercase tracking-[0.24em] text-slate-500">Primary call to action</p>
            <a
              href={site.calendlyUrl}
              target="_blank"
              rel="noreferrer"
              class="mt-2 block text-sm font-semibold text-white hover:text-[var(--color-primary)]"
            >
              Book your 1-hour consult
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="services" class="section-shell">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto mb-14 max-w-3xl text-center">
          <p class="section-kicker">Core services</p>
          <h2 class="section-title">Automations that remove operational drag.</h2>
          <p class="section-copy">
            We fix slow work first. Then we help your team move faster with less busy work.
          </p>
        </div>

        <div class="grid gap-6 md:grid-cols-3">
          <article class="glass-panel relative overflow-hidden rounded-[30px] p-8 md:col-span-2">
            <div class="card-orb"></div>
            <div class="relative space-y-6">
              <span class="feature-icon"><Icon name="insight" class="h-7 w-7" /></span>
              <div>
                <h3 class="text-2xl font-bold text-white sm:text-3xl">{site.services[0].title}</h3>
                <p class="mt-4 max-w-2xl text-base leading-7 text-slate-300">{site.services[0].body}</p>
              </div>
              <div class="flex flex-wrap gap-3">
                {
                  site.services[0].chips.map((chip) => (
                    <span class="chip">{chip}</span>
                  ))
                }
              </div>
            </div>
          </article>

          <article class="glass-panel rounded-[30px] p-8">
            <span class="feature-icon"><Icon name="agent" class="h-7 w-7" /></span>
            <h3 class="mt-6 text-2xl font-bold text-white">{site.services[1].title}</h3>
            <p class="mt-4 text-base leading-7 text-slate-300">{site.services[1].body}</p>
          </article>

          <article class="glass-panel rounded-[30px] p-8">
            <span class="feature-icon"><Icon name="stack" class="h-7 w-7" /></span>
            <h3 class="mt-6 text-2xl font-bold text-white">{site.services[2].title}</h3>
            <p class="mt-4 text-base leading-7 text-slate-300">{site.services[2].body}</p>
          </article>

          <article class="glass-panel rounded-[30px] p-8 md:col-span-2">
            <div class="grid gap-8 md:grid-cols-[1.1fr_0.9fr] md:items-center">
              <div>
                <span class="feature-icon"><Icon name="integration" class="h-7 w-7" /></span>
                <h3 class="mt-6 text-2xl font-bold text-white">{site.services[3].title}</h3>
                <p class="mt-4 text-base leading-7 text-slate-300">{site.services[3].body}</p>
              </div>
              <div class="relative min-h-56 overflow-hidden rounded-[24px] border border-white/10 bg-[linear-gradient(135deg,rgba(95,198,255,0.18),rgba(12,20,32,0.6),rgba(41,88,255,0.22))]">
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_30%,rgba(255,255,255,0.2),transparent_24%),radial-gradient(circle_at_78%_64%,rgba(95,198,255,0.16),transparent_22%)]"></div>
                <div class="absolute inset-5 grid grid-cols-3 gap-3">
                  <div class="mini-panel"></div>
                  <div class="mini-panel mini-panel-wide"></div>
                  <div class="mini-panel"></div>
                  <div class="mini-panel mini-panel-wide"></div>
                  <div class="mini-panel"></div>
                  <div class="mini-panel"></div>
                </div>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section id="service-ladder" class="section-shell border-y border-white/10 bg-white/[0.02]">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto mb-14 max-w-3xl text-center">
          <p class="section-kicker">Service ladder</p>
          <h2 class="section-title">{site.serviceLadder.title}</h2>
          <p class="section-copy">{site.serviceLadder.body}</p>
        </div>

        <div class="grid gap-6 lg:grid-cols-2">
          <article class="glass-panel rounded-[30px] p-8">
            <p class="section-kicker mb-5">Core automations</p>
            <h3 class="text-2xl font-bold text-white">Streamline the process you already run.</h3>
            <div class="mt-6 grid gap-4">
              {
                site.simpleSolutions.map((item) => (
                  <div class="rounded-[20px] border border-white/10 bg-white/4 px-5 py-4 text-sm leading-7 text-slate-300">
                    {item}
                  </div>
                ))
              }
            </div>
          </article>

          <article class="glass-panel rounded-[30px] p-8">
            <p class="section-kicker mb-5">Advanced AI systems</p>
            <h3 class="text-2xl font-bold text-white">When you want AI to do more.</h3>
            <div class="mt-6 grid gap-4">
              {
                site.advancedSolutions.map((item) => (
                  <div class="rounded-[20px] border border-[var(--color-primary)]/15 bg-[var(--color-primary)]/6 px-5 py-4 text-sm leading-7 text-slate-200">
                    {item}
                  </div>
                ))
              }
            </div>
          </article>
        </div>
      </div>
    </section>

    <section id="solutions" class="section-shell">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto mb-14 max-w-3xl text-center">
          <p class="section-kicker">Advanced AI systems</p>
          <h2 class="section-title">What advanced AI architecture looks like.</h2>
          <p class="section-copy">
            After the basics work well, we can build smart AI systems that help your team do more.
          </p>
        </div>

        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {
            site.advancedArchitecture.map((item) => (
              <article class="glass-panel rounded-[28px] p-8">
                <span class="feature-icon"><Icon name="spark" class="h-7 w-7" /></span>
                <h3 class="mt-6 text-2xl font-bold text-white">{item.title}</h3>
                <p class="mt-4 text-base leading-7 text-slate-300">{item.body}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="process" class="section-shell border-y border-white/10 bg-white/[0.02]">
      <div class="mx-auto grid max-w-7xl gap-14 px-4 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:px-8">
        <div class="grid grid-cols-2 gap-4">
          <div class="grid gap-4">
            <div class="process-block h-40">Workflow Audit</div>
            <div class="process-block h-60 process-block-accent">Automation Layer</div>
          </div>
          <div class="grid gap-4 pt-8">
            <div class="process-block h-60 process-block-accent">Agent Systems</div>
            <div class="process-block h-40">Knowledge Layer</div>
          </div>
        </div>

        <div>
          <p class="section-kicker">Methodology</p>
          <h2 class="section-title max-w-xl">How we build your agency multiplier.</h2>
          <p class="section-copy max-w-2xl">
            We do not start with big AI systems. First we clean the work, then we add automations, then we build bigger AI tools if you need them.
          </p>

          <div class="mt-10 grid gap-6">
            {
              site.process.map((item, index) => {
                const iconName = index === 0 ? "eye" : index === 1 ? "key" : "shield";
                return (
                  <div class="flex gap-4 rounded-[24px] border border-white/10 bg-white/4 p-5">
                    <span class="mt-1 flex h-12 w-12 flex-none items-center justify-center rounded-2xl bg-[var(--color-primary)]/12 text-[var(--color-primary)]">
                      <Icon name={iconName} class="h-5 w-5" />
                    </span>
                    <div>
                      <h3 class="text-lg font-bold text-white">{item.title}</h3>
                      <p class="mt-2 text-sm leading-7 text-slate-400">{item.body}</p>
                    </div>
                  </div>
                );
              })
            }
          </div>
        </div>
      </div>
    </section>

    <section class="section-shell">
      <div class="mx-auto max-w-5xl px-4 text-center sm:px-6 lg:px-8">
        <div class="cta-shell">
          <p class="section-kicker">Ready to move</p>
          <h2 class="section-title mx-auto max-w-4xl">
            Ready to remove manual operations?
          </h2>
          <p class="section-copy mx-auto max-w-2xl">
            Book a 1-hour call. We will look at what you should automate now and what AI tools may help later.
          </p>
          <div class="mt-10 flex flex-col justify-center gap-4 sm:flex-row">
            <a
              href={site.calendlyUrl}
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center justify-center rounded-full bg-[var(--color-primary)] px-8 py-4 text-base font-extrabold text-slate-950 transition hover:-translate-y-0.5 hover:bg-[var(--color-primary-strong)]"
            >
              Book a 1-Hour Consult
            </a>
            <a
              href="#contact"
              class="inline-flex items-center justify-center rounded-full border border-white/14 bg-white/8 px-8 py-4 text-base font-bold text-white transition hover:bg-white/12"
            >
              View Contact Details
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
